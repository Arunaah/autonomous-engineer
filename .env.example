# ============================================================
# AUTONOMOUS ENGINEER — ENVIRONMENT CONFIGURATION
# ============================================================

# --- Model Gateway (LiteLLM) ---
LITELLM_BASE_URL=http://localhost:4000

# --- GLM-5 (Main Builder Model) ---
GLM5_API_KEY=your_glm5_api_key_here
GLM5_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- MiniMax (Reviewer Model) ---
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# --- PostgreSQL (Memory Layer) ---
DATABASE_URL=postgresql://ae_user:ae_password@localhost:5432/autonomous_engineer

# --- Qdrant (Semantic Vector DB) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=codebase_index

# --- GitHub ---
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=your_username/your_repo

# --- Confidence Threshold ---
CONFIDENCE_THRESHOLD=95
MAX_ITERATIONS=9

# --- Embedding Model (CodeSage / CodeBERT) ---
EMBEDDING_MODEL=microsoft/codebert-base

# --- Logging ---
LOG_LEVEL=INFO
